#!/bin/bash
set -euo pipefail

# --- Creating color variables and logger methods. ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[INFO]${NC}    $*"; }
success() { echo -e "${GREEN}[OK]${NC}      $*"; }
warning() { echo -e "${YELLOW}[WARN]${NC}   $*"; }
error()   { echo -e "${RED}[ERROR]${NC}  $*" >&2; exit 1; }

# --- Check if script is executed as sudo. ---
[[ $EUID -ne 0 ]] && error "Run this script with sudo."

# --- Parse optional arguments. ---
UPDATE_BASE=true
UPDATE_MARIADB=true
UPDATE_POSTGRESQL=true
UPDATE_TEMPLATES=true
UPDATE_SNIPPETS=true

for arg in "$@"; do
  case $arg in
    --no-base)        UPDATE_BASE=false ;;
    --no-mariadb)     UPDATE_MARIADB=false ;;
    --no-postgresql)  UPDATE_POSTGRESQL=false ;;
    --no-templates)   UPDATE_TEMPLATES=false ;;
    --no-snippets)    UPDATE_SNIPPETS=false ;;
    *) error "Unknown argument: $arg" ;;
  esac
done

GITHUB_RAW="https://raw.githubusercontent.com/Almighty-Shogun/nginx-ubuntu/main"

echo ""
info "Updating files..."
echo ""

# --- Update base scripts. ---
if [[ "$UPDATE_BASE" == true ]]; then
  for script in create-website disable-website enable-website remove-website update-files; do
    curl -fsSL "$GITHUB_RAW/scripts/$script" -o /usr/local/bin/$script
    chmod +x /usr/local/bin/$script
    success "$script has been updated."
  done
fi

# --- Update MariaDB scripts if installed. ---
if [[ "$UPDATE_MARIADB" == true ]] && [[ -f /usr/local/bin/mariadb-add-user ]]; then
  for script in mariadb-add-user mariadb-remove-user mariadb-update-password; do
    curl -fsSL "$GITHUB_RAW/scripts/$script" -o /usr/local/bin/$script
    chmod +x /usr/local/bin/$script
    success "$script has been updated."
  done
fi

# --- Update PostgreSQL scripts if installed. ---
if [[ "$UPDATE_POSTGRESQL" == true ]] && [[ -f /usr/local/bin/postgresql-add-user ]]; then
  for script in postgresql-add-user postgresql-remove-user postgresql-update-password; do
    curl -fsSL "$GITHUB_RAW/scripts/$script" -o /usr/local/bin/$script
    chmod +x /usr/local/bin/$script
    success "$script has been updated."
  done
fi

# --- Update NGINX templates. ---
if [[ "$UPDATE_TEMPLATES" == true ]] && [[ -d /etc/nginx/templates ]]; then
  for template in nginx-php nginx-dotnet nginx-vue nginx-html nginx-node dotnet-app.service node-app.service asp_index php_index vue_index html_index node_package node_server bun_package bun_server; do
    curl -fsSL "$GITHUB_RAW/templates/$template.template" -o /etc/nginx/templates/$template.template
    success "$template.template has been updated."
  done
fi

# --- Update NGINX snippets. ---
if [[ "$UPDATE_SNIPPETS" == true ]] && [[ -d /etc/nginx/snippets ]]; then
  for conf in cloudflare-real-ip security-headers fastcgi-php; do
    curl -fsSL "$GITHUB_RAW/snippets/$conf.conf" -o /etc/nginx/snippets/$conf.conf
    success "$conf.conf has been updated."
  done
fi

echo ""
success "Done."
echo ""
