#!/bin/bash
set -euo pipefail

# --- Creating color variables and logger methods. ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[INFO]${NC}    $*"; }
success() { echo -e "${GREEN}[OK]${NC}      $*"; }
warning() { echo -e "${YELLOW}[WARN]${NC}   $*"; }
error()   { echo -e "${RED}[ERROR]${NC}  $*" >&2; exit 1; }

# --- Check if script is executed as sudo. ---
[[ $EUID -ne 0 ]] && error "Run this script with sudo."

# --- Check if MariaDB is installed. ---
command -v mariadb &>/dev/null || error "MariaDB is not installed."

# --- Parse optional arguments. ---
USERNAME_ARG=""

for arg in "$@"; do
  case $arg in
    --user=*) USERNAME_ARG="${arg#*=}" ;;
    *) error "Unknown argument: $arg" ;;
  esac
done

# --- Ask for user details. ---
echo ""
info "Updating MariaDB password..."
echo ""

if [[ -n "$USERNAME_ARG" ]]; then
  username="$USERNAME_ARG"
  info "Updating password for user: $username"
else
  while true; do
    read -rp "Enter username: " username
    [[ -n "$username" ]] && break
    echo "You did not provide a username. Please try again."
  done
fi

[[ ! "$username" =~ ^[a-zA-Z0-9_]+$ ]] && error "Username may only contain letters, numbers, and underscores."

# --- Check if user exists. ---
USER_EXISTS=$(mariadb -sse "SELECT COUNT(*) FROM mysql.user WHERE user='$username' AND host='localhost';")
[[ "$USER_EXISTS" -eq 0 ]] && error "User '$username' does not exist."

while true; do
  read -rsp "Enter new password: " newPassword
  echo ""
  [[ -n "$newPassword" ]] && break
  echo "You did not provide a password. Please try again."
done

while true; do
  read -rsp "Confirm new password: " confirmPassword
  echo ""
  [[ "$newPassword" == "$confirmPassword" ]] && break
  echo "Passwords do not match. Please try again."
done

# --- Escape special characters in password for SQL string literals. ---
sql_password="${newPassword//\\/\\\\}"
sql_password="${sql_password//\'/\'\'}"

# --- Update password. ---
info "Applying new password..."

mariadb <<EOF
ALTER USER '$username'@'localhost' IDENTIFIED BY '$sql_password';
FLUSH PRIVILEGES;
EOF

success "Password for '$username' has been updated."
