#!/bin/bash
set -euo pipefail

# --- Creating color variables and logger methods. ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[INFO]${NC}    $*"; }
success() { echo -e "${GREEN}[OK]${NC}      $*"; }
warning() { echo -e "${YELLOW}[WARN]${NC}   $*"; }
error()   { echo -e "${RED}[ERROR]${NC}  $*" >&2; exit 1; }

# --- Check if script is executed as sudo. ---
[[ $EUID -ne 0 ]] && error "Run this script with sudo."

# --- Check if MariaDB is installed. ---
command -v mariadb &>/dev/null || error "MariaDB is not installed."

# --- Parse optional arguments. ---
USERNAME_ARG=""
FORCE=false

for arg in "$@"; do
  case $arg in
    --user=*) USERNAME_ARG="${arg#*=}" ;;
    --force) FORCE=true ;;
    *) error "Unknown argument: $arg" ;;
  esac
done

# --- Ask for username. ---
echo ""
info "Removing a MariaDB user..."
echo ""

if [[ -n "$USERNAME_ARG" ]]; then
  username="$USERNAME_ARG"
  info "Removing user: $username"
else
  while true; do
    read -rp "Enter username to remove: " username
    [[ -n "$username" ]] && break
    echo "You did not provide a username. Please try again."
  done
fi

[[ ! "$username" =~ ^[a-zA-Z0-9_]+$ ]] && error "Username may only contain letters, numbers, and underscores."

# --- Check if user exists. ---
USER_EXISTS=$(mariadb -sse "SELECT COUNT(*) FROM mysql.user WHERE user='$username' AND host='localhost';")
[[ "$USER_EXISTS" -eq 0 ]] && error "User '$username' does not exist."

# --- Confirm deletion. ---
if [[ "$FORCE" == false ]]; then
  echo ""
  warning "This will permanently remove user '$username' and all their privileges."
  echo ""
  read -rp "Type the username to confirm: " confirmUsername

  if [[ "$confirmUsername" != "$username" ]]; then
    info "Username did not match. Aborted."
    exit 0
  fi
fi

# --- Remove user. ---
info "Removing user '$username'..."

mariadb <<EOF
DROP USER '$username'@'localhost';
FLUSH PRIVILEGES;
EOF

success "User '$username' has been removed."
