#!/bin/bash
set -euo pipefail

# --- Creating color variables and logger methods. ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${CYAN}[INFO]${NC}    $*"; }
success() { echo -e "${GREEN}[OK]${NC}      $*"; }
warning() { echo -e "${YELLOW}[WARN]${NC}   $*"; }
error()   { echo -e "${RED}[ERROR]${NC}  $*" >&2; exit 1; }
ask()     { echo -e "${BOLD}$*${NC}"; }

TEMPLATES_PATH="/etc/nginx/templates"

# --- Check if script is executed as sudo with the correct arguments. ---
[[ $EUID -ne 0 ]] && error "Run this script with sudo."
[[ $# -lt 1 ]] && error "Usage: sudo create-website <domain.com> [--type=php|dotnet|vue|html|node|bun] [--php-version=8.3] [--port=3000] [--assembly=MyProject] [--start-command='npm run start']"

DOMAIN="$1"
shift

# --- Parse optional arguments. ---
SITE_TYPE_ARG=""
PHP_VERSION_ARG=""
APP_PORT_ARG=""
DOTNET_ASSEMBLY_ARG=""
START_COMMAND_ARG=""

for arg in "$@"; do
  case $arg in
    --type=*) SITE_TYPE_ARG="${arg#*=}" ;;
    --php-version=*) PHP_VERSION_ARG="${arg#*=}" ;;
    --port=*) APP_PORT_ARG="${arg#*=}" ;;
    --assembly=*) DOTNET_ASSEMBLY_ARG="${arg#*=}" ;;
    --start-command=*) START_COMMAND_ARG="${arg#*=}" ;;
    *) error "Unknown argument: $arg" ;;
  esac
done

validate_port() {
  local port="$1"
  [[ "$port" =~ ^[0-9]+$ ]] && [[ "$port" -ge 1 ]] && [[ "$port" -le 65535 ]]
}

escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[&|\\]/\\&/g'
}

# --- Checking if the domain is a valid domain name. ---
if ! echo "$DOMAIN" | grep -qP '^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?(\.[a-zA-Z0-9-]{1,63})+$'; then
  error "\"$DOMAIN\" doesn't look like a valid domain name."
fi

# --- Checking if domain or domain config already exists. ---
[[ -d "/var/www/$DOMAIN" ]] && error "Directory /var/www/$DOMAIN already exists."
[[ -f "/etc/nginx/conf.d/$DOMAIN.conf" ]] && error "NGINX config for $DOMAIN already exists."

# --- Checking if NGINX and CloudFlared are installed. ---
command -v nginx &>/dev/null || error "NGINX is not installed."

# --- Select website type. ---
SITE_TYPE=""
if [[ -n "$SITE_TYPE_ARG" ]]; then
  case $SITE_TYPE_ARG in
    php) SITE_TYPE="1" ;;
    dotnet) SITE_TYPE="2" ;;
    vue) SITE_TYPE="3" ;;
    html) SITE_TYPE="4" ;;
    node) SITE_TYPE="5" ;;
    bun) SITE_TYPE="6" ;;
    *) error "Invalid --type value. Use php, dotnet, vue, html, node or bun." ;;
  esac
else
  echo ""
  ask "What type of site is this?"
  echo ""
  echo "  [1] PHP"
  echo "  [2] ASP.NET"
  echo "  [3] Vue"
  echo "  [4] HTML"
  echo "  [5] Node"
  echo "  [6] Bun"
  echo ""
  read -rp "Enter number [1-6]: " SITE_TYPE
fi

case $SITE_TYPE in
  1) SITE_LABEL="PHP"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-php.template" ;;
  2) SITE_LABEL="ASP.NET"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-dotnet.template" ;;
  3) SITE_LABEL="Vue"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-vue.template" ;;
  4) SITE_LABEL="HTML"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-html.template" ;;
  5) SITE_LABEL="Node"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-node.template" ;;
  6) SITE_LABEL="Bun"
    TEMPLATE_PATH="$TEMPLATES_PATH/nginx-node.template" ;;
  *) error "Invalid choice." ;;
esac

# --- Check if the template exists. ---
[[ ! -f "$TEMPLATE_PATH" ]] && error "Template not found at $TEMPLATE_PATH."

# --- Options for PHP websites. ---
PHP_VERSION=""
if [[ "$SITE_TYPE" == "1" ]]; then
  if [[ -n "$PHP_VERSION_ARG" ]]; then
    [[ ! -S "/run/php/php${PHP_VERSION_ARG}-fpm.sock" ]] && error "PHP ${PHP_VERSION_ARG}-FPM is not running."
    PHP_VERSION="$PHP_VERSION_ARG"
    success "Using PHP $PHP_VERSION"
  else
    echo ""
    ask "Which PHP version should this site use?"
    echo ""

    AVAILABLE_PHP=()
    for sock in /run/php/php*-fpm.sock; do
      ver=$(echo "$sock" | grep -oP '\d+\.\d+')
      AVAILABLE_PHP+=("$ver")
      echo "  [${#AVAILABLE_PHP[@]}] PHP $ver"
    done

    [[ ${#AVAILABLE_PHP[@]} -eq 0 ]] && error "No PHP-FPM versions are running."

    echo ""
    read -rp "Enter number [1-${#AVAILABLE_PHP[@]}]: " PHP_CHOICE

    if ! [[ "$PHP_CHOICE" =~ ^[0-9]+$ ]] || [[ "$PHP_CHOICE" -lt 1 ]] || [[ "$PHP_CHOICE" -gt ${#AVAILABLE_PHP[@]} ]]; then
      error "Invalid choice."
    fi

    PHP_VERSION="${AVAILABLE_PHP[$((PHP_CHOICE - 1))]}"
    success "Selected PHP $PHP_VERSION"
  fi
fi

# --- Options for ASP.NET websites. ---
APP_PORT=""
DOTNET_ASSEMBLY=""
if [[ "$SITE_TYPE" == "2" ]]; then
  if [[ -n "$APP_PORT_ARG" ]]; then
    validate_port "$APP_PORT_ARG" || error "Invalid --port value. Use a number between 1 and 65535."
    APP_PORT="$APP_PORT_ARG"
    success "Using port $APP_PORT"
  else
    echo ""
    read -rp "Which localhost port is your ASP.NET app running on? [default: 5000]: " APP_PORT
    APP_PORT="${APP_PORT:-5000}"
    validate_port "$APP_PORT" || error "Invalid port. Use a number between 1 and 65535."
    success "Using port $APP_PORT"
  fi

  if [[ -n "$DOTNET_ASSEMBLY_ARG" ]]; then
    DOTNET_ASSEMBLY="$DOTNET_ASSEMBLY_ARG"
    success "Using assembly $DOTNET_ASSEMBLY"
  else
    echo ""
    read -rp "What is the name of your ASP.NET assembly (e.g. MyProject): " DOTNET_ASSEMBLY
    [[ -z "$DOTNET_ASSEMBLY" ]] && error "You did not provide an assembly name."
    success "Using assembly $DOTNET_ASSEMBLY"
  fi
fi

# --- Options for Node/Bun websites. ---
START_COMMAND=""
if [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  DEFAULT_PORT="3000"
  DEFAULT_START_COMMAND="npm run start"
  RUNTIME_BINARY="node"

  if [[ "$SITE_TYPE" == "6" ]]; then
    DEFAULT_START_COMMAND="bun run start"
    RUNTIME_BINARY="bun"
  fi

  if [[ -n "$APP_PORT_ARG" ]]; then
    validate_port "$APP_PORT_ARG" || error "Invalid --port value. Use a number between 1 and 65535."
    APP_PORT="$APP_PORT_ARG"
    success "Using port $APP_PORT"
  else
    echo ""
    read -rp "Which localhost port should the $SITE_LABEL app listen on? [default: $DEFAULT_PORT]: " APP_PORT
    APP_PORT="${APP_PORT:-$DEFAULT_PORT}"
    validate_port "$APP_PORT" || error "Invalid port. Use a number between 1 and 65535."
    success "Using port $APP_PORT"
  fi

  if [[ -n "$START_COMMAND_ARG" ]]; then
    START_COMMAND="$START_COMMAND_ARG"
    success "Using start command: $START_COMMAND"
  else
    echo ""
    read -rp "Start command from /var/www/$DOMAIN/app [default: $DEFAULT_START_COMMAND]: " START_COMMAND
    START_COMMAND="${START_COMMAND:-$DEFAULT_START_COMMAND}"
    success "Using start command: $START_COMMAND"
  fi

  [[ -z "$START_COMMAND" ]] && error "You did not provide a start command."
  [[ "$START_COMMAND" == *$'\n'* ]] && error "Start command cannot contain newlines."

  command -v "$RUNTIME_BINARY" &>/dev/null || warning "$RUNTIME_BINARY was not found in PATH. Install it before starting the $DOMAIN service."
fi

# --- Determine www coverage. ---
DOT_COUNT=$(echo "$DOMAIN" | tr -cd '.' | wc -c)
if [[ "$DOT_COUNT" -gt 1 ]]; then
  INCLUDE_WWW="N"
else
  INCLUDE_WWW="Y"
fi

# --- Ask for domain confirmation. ---
echo ""
echo -e "${BOLD}Summary${NC}"
echo "  Domain       : $DOMAIN"
[[ "$INCLUDE_WWW" == "Y" ]] && echo "  Also covers  : www.$DOMAIN"
echo "  Type         : $SITE_LABEL"
[[ -n "$PHP_VERSION" ]]     && echo "  PHP version  : $PHP_VERSION"
[[ -n "$APP_PORT" ]]        && echo "  App port     : $APP_PORT"
[[ -n "$DOTNET_ASSEMBLY" ]] && echo "  .NET assembly: $DOTNET_ASSEMBLY"
[[ -n "$START_COMMAND" ]]   && echo "  Start command: $START_COMMAND"
echo "  Webroot      : /var/www/$DOMAIN/public"
echo "  Logs         : /var/www/$DOMAIN/logs"
echo "  NGINX config : /etc/nginx/conf.d/$DOMAIN.conf"
if [[ "$SITE_TYPE" == "2" ]] || [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  echo "  Service      : /etc/systemd/system/$DOMAIN.service"
fi
echo ""
read -rp "Proceed? [Y/n] " CONFIRM
CONFIRM="${CONFIRM:-Y}"
[[ ! "$CONFIRM" =~ ^[Yy]$ ]] && { info "Aborted."; exit 0; }

# --- Create directory structure. ---
info "Creating directory structure..."

# App-server types need the app directory
if [[ "$SITE_TYPE" == "2" ]] || [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  mkdir -p "/var/www/$DOMAIN"/{public,logs,app}
else
  mkdir -p "/var/www/$DOMAIN"/{public,logs}
fi

chown -R www-data:www-data "/var/www/$DOMAIN"
chmod -R 755 "/var/www/$DOMAIN"

case $SITE_TYPE in
  1)
    sed "s/{{DOMAIN}}/$DOMAIN/g" "$TEMPLATES_PATH/php_index.template" > "/var/www/$DOMAIN/public/index.php"
    chown www-data:www-data "/var/www/$DOMAIN/public/index.php" ;;
  2)
    sed "s/{{DOMAIN}}/$DOMAIN/g" "$TEMPLATES_PATH/asp_index.template" > "/var/www/$DOMAIN/public/index.html"
    chown www-data:www-data "/var/www/$DOMAIN/public/index.html" ;;
  3)
    sed "s/{{DOMAIN}}/$DOMAIN/g" "$TEMPLATES_PATH/vue_index.template" > "/var/www/$DOMAIN/public/index.html"
    chown www-data:www-data "/var/www/$DOMAIN/public/index.html" ;;
  4)
    sed "s/{{DOMAIN}}/$DOMAIN/g" "$TEMPLATES_PATH/html_index.template" > "/var/www/$DOMAIN/public/index.html"
    chown www-data:www-data "/var/www/$DOMAIN/public/index.html" ;;
  5)
    sed \
      -e "s|{{DOMAIN}}|$DOMAIN|g" \
      -e "s|{{APP_PORT}}|$APP_PORT|g" \
      "$TEMPLATES_PATH/node_package.template" > "/var/www/$DOMAIN/app/package.json"
    sed \
      -e "s|{{DOMAIN}}|$DOMAIN|g" \
      -e "s|{{APP_PORT}}|$APP_PORT|g" \
      "$TEMPLATES_PATH/node_server.template" > "/var/www/$DOMAIN/app/server.js"
    chown www-data:www-data "/var/www/$DOMAIN/app/package.json" "/var/www/$DOMAIN/app/server.js" ;;
  6)
    sed \
      -e "s|{{DOMAIN}}|$DOMAIN|g" \
      -e "s|{{APP_PORT}}|$APP_PORT|g" \
      "$TEMPLATES_PATH/bun_package.template" > "/var/www/$DOMAIN/app/package.json"
    sed \
      -e "s|{{DOMAIN}}|$DOMAIN|g" \
      -e "s|{{APP_PORT}}|$APP_PORT|g" \
      "$TEMPLATES_PATH/bun_server.template" > "/var/www/$DOMAIN/app/server.js"
    chown www-data:www-data "/var/www/$DOMAIN/app/package.json" "/var/www/$DOMAIN/app/server.js" ;;
esac

success "Directories created."

# --- Create NGINX configuration. ---
info "Generating NGINX config..."

NGINX_CONF="/etc/nginx/conf.d/$DOMAIN.conf"
sed \
  -e "s|{{DOMAIN}}|$DOMAIN|g" \
  -e "s|{{PHP_VERSION}}|$PHP_VERSION|g" \
  -e "s|{{DOTNET_PORT}}|$APP_PORT|g" \
  -e "s|{{APP_PORT}}|$APP_PORT|g" \
  "$TEMPLATE_PATH" > "$NGINX_CONF"

if [[ "$INCLUDE_WWW" == "N" ]]; then
  sed -i "s| www\.$DOMAIN||g" "$NGINX_CONF"
fi

success "Config written to $NGINX_CONF"

# --- Create systemd service for ASP.NET. ---
if [[ "$SITE_TYPE" == "2" ]]; then
  info "Creating systemd service..."

  SERVICE_TEMPLATE="$TEMPLATES_PATH/dotnet-app.service.template"
  [[ ! -f "$SERVICE_TEMPLATE" ]] && error "Service template not found at $SERVICE_TEMPLATE."

  sed \
    -e "s|{{DOMAIN}}|$DOMAIN|g" \
    -e "s|{{ASSEMBLY}}|$DOTNET_ASSEMBLY|g" \
    -e "s|{{DOTNET_PORT}}|$APP_PORT|g" \
    "$SERVICE_TEMPLATE" > "/etc/systemd/system/$DOMAIN.service"

  systemctl daemon-reload
  systemctl enable "$DOMAIN"

  success "Systemd service created and enabled."
fi

# --- Create systemd service for Node/Bun. ---
if [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  info "Creating systemd service..."

  SERVICE_TEMPLATE="$TEMPLATES_PATH/node-app.service.template"
  [[ ! -f "$SERVICE_TEMPLATE" ]] && error "Service template not found at $SERVICE_TEMPLATE."

  START_COMMAND_ESCAPED="$(escape_sed_replacement "$START_COMMAND")"

  sed \
    -e "s|{{DOMAIN}}|$DOMAIN|g" \
    -e "s|{{SITE_LABEL}}|$SITE_LABEL|g" \
    -e "s|{{APP_PORT}}|$APP_PORT|g" \
    -e "s|{{START_COMMAND}}|$START_COMMAND_ESCAPED|g" \
    "$SERVICE_TEMPLATE" > "/etc/systemd/system/$DOMAIN.service"

  systemctl daemon-reload
  systemctl enable "$DOMAIN"

  success "Systemd service created and enabled."
fi

# --- Test and reload NGINX. ---
info "Testing NGINX config..."
nginx -t || {
  warning "NGINX test failed — rolling back."
  rm -f "$NGINX_CONF"
  rm -rf "/var/www/$DOMAIN"
  if [[ "$SITE_TYPE" == "2" ]] || [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
    rm -f "/etc/systemd/system/$DOMAIN.service"
  fi
  error "Fix the config at $NGINX_CONF then re-enable manually."
}

nginx -s reload
success "NGINX reloaded."

# --- Script execution summary. ---
echo ""
echo -e "${GREEN}${BOLD}$DOMAIN is live!${NC}"
echo ""
echo "  Webroot  → /var/www/$DOMAIN/public"
echo "  Logs     → /var/www/$DOMAIN/logs"
echo "  Config   → /etc/nginx/conf.d/$DOMAIN.conf"
echo "  Type     → $SITE_LABEL"
[[ -n "$PHP_VERSION" ]]     && echo "  PHP      → $PHP_VERSION"
[[ -n "$APP_PORT" ]]        && echo "  Port     → $APP_PORT"
[[ -n "$DOTNET_ASSEMBLY" ]] && echo "  Assembly → $DOTNET_ASSEMBLY"
if [[ "$SITE_TYPE" == "2" ]] || [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  echo "  Service  → /etc/systemd/system/$DOMAIN.service"
fi
echo ""

if [[ "$SITE_TYPE" == "2" ]] || [[ "$SITE_TYPE" == "5" ]] || [[ "$SITE_TYPE" == "6" ]]; then
  warning "Start the service once your app is deployed: systemctl start $DOMAIN"
fi

if [[ "$INCLUDE_WWW" == "Y" ]]; then
  warning "Don't forget to add $DOMAIN rule in your CloudFlare Tunnel dashboard."
fi
