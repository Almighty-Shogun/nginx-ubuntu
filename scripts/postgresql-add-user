#!/bin/bash
set -euo pipefail

# --- Creating color variables and logger methods. ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${CYAN}[INFO]${NC}    $*"; }
success() { echo -e "${GREEN}[OK]${NC}      $*"; }
warning() { echo -e "${YELLOW}[WARN]${NC}   $*"; }
error()   { echo -e "${RED}[ERROR]${NC}  $*" >&2; exit 1; }

# --- Check if script is executed as sudo. ---
[[ $EUID -ne 0 ]] && error "Run this script with sudo."

# --- Check if PostgreSQL is installed. ---
command -v psql &>/dev/null || error "PostgreSQL is not installed."

# --- Parse optional arguments. ---
USERNAME_ARG=""
DATABASE_ARG=""
GRANT=false

for arg in "$@"; do
  case $arg in
    --user=*) USERNAME_ARG="${arg#*=}" ;;
    --database=*) DATABASE_ARG="${arg#*=}" ;;
    --grant) GRANT=true ;;
    *) error "Unknown argument: $arg" ;;
  esac
done

[[ "$GRANT" == true ]] && [[ -z "$DATABASE_ARG" ]] && error "--grant requires --database."

# --- Ask for username. ---
echo ""
if [[ "$GRANT" == true ]]; then
  info "Granting PostgreSQL database access..."
else
  info "Adding a new PostgreSQL user..."
fi
echo ""

if [[ -n "$USERNAME_ARG" ]]; then
  username="$USERNAME_ARG"
  info "Using username: $username"
else
  while true; do
    read -rp "Enter username: " username
    [[ -n "$username" ]] && break
    echo "You did not provide a username. Please try again."
  done
fi

[[ ! "$username" =~ ^[a-zA-Z0-9_]+$ ]] && error "Username may only contain letters, numbers, and underscores."

if [[ "$GRANT" == true ]]; then
  # --- Grant mode: verify user exists, skip creation. ---
  USER_EXISTS=$(sudo -u postgres psql -tAq -c "SELECT COUNT(*) FROM pg_roles WHERE rolname='$username';")
  [[ "$USER_EXISTS" -eq 0 ]] && error "User '$username' does not exist."
else
  # --- Create mode: ask for password and create user. ---
  while true; do
    read -rsp "Enter password: " password
    echo ""
    [[ -n "$password" ]] && break
    echo "You did not provide a password. Please try again."
  done

  while true; do
    read -rsp "Confirm password: " confirmPassword
    echo ""
    [[ "$password" == "$confirmPassword" ]] && break
    echo "Passwords do not match. Please try again."
  done

  sql_password="${password//\'/\'\'}"

  info "Creating user '$username'..."

  sudo -u postgres psql -q <<EOF
CREATE USER "$username" WITH PASSWORD '$sql_password' NOSUPERUSER NOCREATEDB NOCREATEROLE;
EOF

  success "User '$username' has been created with no database access."
fi

# --- Create database if provided, then grant access. ---
if [[ -n "$DATABASE_ARG" ]]; then
  DB_EXISTS=$(sudo -u postgres psql -tAq -c "SELECT COUNT(*) FROM pg_database WHERE datname='$DATABASE_ARG';")

  if [[ "$DB_EXISTS" -eq 0 ]]; then
    info "Database '$DATABASE_ARG' does not exist — creating it..."
    sudo -u postgres psql -q <<EOF
CREATE DATABASE "$DATABASE_ARG";
EOF
    success "Database '$DATABASE_ARG' created."
  else
    info "Database '$DATABASE_ARG' already exists — skipping creation."
  fi

  sudo -u postgres psql -q <<EOF
GRANT ALL PRIVILEGES ON DATABASE "$DATABASE_ARG" TO "$username";
EOF
  success "Granted '$username' full access to '$DATABASE_ARG'."
fi
